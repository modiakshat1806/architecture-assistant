generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id        String    @id @db.Uuid
  email     String    @unique
  name      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  
  projects  Project[]
  githubConnection GitHubConnection?
  slackIntegration SlackIntegration?
}

model Project {
  id          String       @id @default(uuid()) @db.Uuid
  profileId   String       @db.Uuid
  name        String
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  profile     Profile      @relation(fields: [profileId], references: [id], onDelete: Cascade)
  prdVersions PrdVersion[]
  activities  Activity[]
}

model PrdVersion {
  id             String    @id @default(uuid()) @db.Uuid
  projectId      String    @db.Uuid
  versionNumber  Int       
  fileUrl        String?   
  parsedText     String    @db.Text
  createdAt      DateTime  @default(now())

  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  analysis       PipelineAnalysis? 
}

model PipelineAnalysis {
  id             String     @id @default(uuid()) @db.Uuid
  prdVersionId   String     @unique @db.Uuid
  
  features       Json       @default("[]")
  stories        Json       @default("[]")
  tasks          Json       @default("[]")
  sprints        Json       @default("[]")
  architecture   String?    @db.Text
  codeStructure  Json       @default("[]")
  tests          Json       @default("[]")
  traceability   Json       @default("{}")
  ambiguities    Json       @default("[]")
  clarifications Json       @default("[]")
  healthScore    Json       @default("{}")
  devops         Json       @default("{}")
  
  changeImpact   Json?

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  prdVersion     PrdVersion @relation(fields: [prdVersionId], references: [id], onDelete: Cascade)
}
model ClarificationAnswer {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @db.Uuid
  question   String
  answer     String
  createdAt  DateTime @default(now())
}

